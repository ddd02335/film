<Window x:Class="MovieApp.ImportRatingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Импорт оценок" Height="280" Width="340"
        WindowStartupLocation="CenterOwner" Background="#141414" ResizeMode="NoResize">
    <StackPanel Margin="20" VerticalAlignment="Center">
        <TextBlock Text="Логин аккаунта-источника:" Foreground="#AAAAAA" Margin="0,0,0,5"/>
        <TextBox x:Name="TxtLogin" Background="#2A2A2A" Foreground="White" BorderThickness="0" Padding="8" Margin="0,0,0,15"/>
        
        <TextBlock Text="Пароль:" Foreground="#AAAAAA" Margin="0,0,0,5"/>
        <PasswordBox x:Name="TxtPassword" Background="#2A2A2A" Foreground="White" BorderThickness="0" Padding="8" Margin="0,0,0,25"/>
        
        <Button x:Name="BtnImport" Content="Импортировать" Background="#E50914" Foreground="White" BorderThickness="0" Padding="10" FontWeight="Bold" Cursor="Hand" Click="BtnImport_Click"/>
    </StackPanel>
</Window>

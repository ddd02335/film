<Page x:Class="MovieApp.Pages.AdminImportPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
      Background="#141414">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- панель управления -->
        <Border Grid.Row="0" Background="#1F1F1F" Padding="24,20"
                BorderThickness="0,0,0,1" BorderBrush="#2A2A2A">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <iconPacks:PackIconMaterial Kind="Cog" Width="16" Height="16" Foreground="#FFA500" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="Импорт фильмов из Кинопоиска API"
                               FontSize="16" FontWeight="Bold" Foreground="#FFA500"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- API ключ -->
                <TextBlock Text="Кинопоиск API Key (X-API-KEY)" Foreground="#B3B3B3" FontSize="12" Margin="0,0,0,6"/>
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Background="#2A2A2A" CornerRadius="6" Grid.Column="0">
                        <TextBox x:Name="TxtApiKey"
                                 Background="Transparent"
                                 Foreground="#FFFFFF"
                                 CaretBrush="#E50914"
                                 BorderThickness="0"
                                 Padding="12,8"
                                 FontSize="13"
                                 FontFamily="Consolas"/>
                    </Border>
                    <!-- количество страниц -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="12,0,0,0">
                        <TextBlock Text="Страниц:" Foreground="#B3B3B3" FontSize="12"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <Border Background="#2A2A2A" CornerRadius="6" Width="80">
                            <TextBox x:Name="TxtPages"
                                     Text="3"
                                     Background="Transparent"
                                     Foreground="#FFFFFF"
                                     CaretBrush="#E50914"
                                     BorderThickness="0"
                                     Padding="10,8"
                                     FontSize="13"
                                     HorizontalContentAlignment="Center"/>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- кнопка запуска -->
                <Button x:Name="BtnImport"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Width="200"
                        HorizontalAlignment="Left"
                        Height="40"
                        Click="BtnImport_Click">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <iconPacks:PackIconMaterial Kind="Play" Width="14" Height="14" Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Запустить импорт" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <!-- область логов -->
        <Grid Grid.Row="1" Margin="24,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock Text="Лог выполнения"
                           FontSize="13" FontWeight="SemiBold" Foreground="#B3B3B3"
                           VerticalAlignment="Center"/>
                <Button Content="Очистить"
                        Background="Transparent"
                        Foreground="#6B6B6B"
                        BorderThickness="0"
                        FontSize="12"
                        Cursor="Hand"
                        Margin="16,0,0,0"
                        Click="BtnClearLog_Click"/>
            </StackPanel>

            <Border Grid.Row="1" Background="#1F1F1F" CornerRadius="8">
                <ScrollViewer x:Name="LogScroll" VerticalScrollBarVisibility="Auto" Padding="4">
                    <TextBlock x:Name="TxtLog"
                               FontFamily="Consolas"
                               FontSize="12"
                               Foreground="#B3B3B3"
                               Padding="12"
                               TextWrapping="Wrap"
                               Text="Введите API-ключ Кинопоиска и нажмите «Запустить импорт»..."/>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Page>

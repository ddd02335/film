<Page x:Class="MovieApp.Pages.WatchedPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#141414">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock x:Name="TxtCount"
                           Text="Загрузка..."
                           FontSize="13"
                           Foreground="#6B6B6B"
                           Margin="24,20,24,12"/>

                <!-- список оценённых фильмов -->
                <ItemsControl x:Name="WatchedList" Margin="16,0,16,16">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#1F1F1F"
                                    CornerRadius="8"
                                    Margin="8,4"
                                    Padding="0">
                                <Border.Effect>
                                    <DropShadowEffect Color="#000000" BlurRadius="8" Opacity="0.3" ShadowDepth="1"/>
                                </Border.Effect>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- мини-постер -->
                                    <Border Grid.Column="0" CornerRadius="8,0,0,8" ClipToBounds="True"
                                            Width="80" Height="108">
                                        <Grid>
                                            <Border Background="#2A2A2A">
                                                <TextBlock Text="🎬" FontSize="28"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <Image Source="{Binding PosterUrl}"
                                                   Stretch="UniformToFill"/>
                                        </Grid>
                                    </Border>

                                    <!-- информация о фильме -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="16,12">
                                        <TextBlock Text="{Binding Title}"
                                                   FontSize="15" FontWeight="SemiBold"
                                                   Foreground="#FFFFFF"
                                                   TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding Year}"
                                                   FontSize="12"
                                                   Foreground="#6B6B6B"
                                                   Margin="0,4,0,8"/>
                                        <TextBlock Text="{Binding Genres}"
                                                   FontSize="12"
                                                   Foreground="#B3B3B3"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>

                                    <!-- оценка и кнопка удаления -->
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center"
                                                HorizontalAlignment="Center"
                                                Margin="12,0"
                                                MinWidth="120">
                                        <TextBlock Text="{Binding StarText}"
                                                   FontSize="18"
                                                   HorizontalAlignment="Center"
                                                   Foreground="#FFA500"/>
                                        <TextBlock Text="{Binding ScoreLabel}"
                                                   FontSize="11"
                                                   Foreground="#6B6B6B"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,2,0,4"/>
                                        
                                        <!-- кнопка удаления -->
                                        <Button Content="✖ Удалить"
                                                Tag="{Binding Id}"
                                                Click="BtnDelete_Click"
                                                FontSize="11"
                                                Foreground="#E50914"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Cursor="Hand"
                                                HorizontalAlignment="Center">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <TextBlock x:Name="Txt" 
                                                               Text="{TemplateBinding Content}"
                                                               Foreground="{TemplateBinding Foreground}"
                                                               Background="Transparent"/>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Txt" Property="Foreground" Value="#FF4D4D"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- пустое состояние -->
                <StackPanel x:Name="PanelEmpty"
                            HorizontalAlignment="Center"
                            Margin="0,60,0,0"
                            Visibility="Collapsed">
                    <TextBlock Text="🎭" FontSize="64" HorizontalAlignment="Center"/>
                    <TextBlock Text="Вы ещё не оценили ни одного фильма"
                               FontSize="20" FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Margin="0,16,0,8"/>
                    <TextBlock Text="Перейдите в каталог и оцените первый фильм"
                               FontSize="14"
                               Foreground="#6B6B6B"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>

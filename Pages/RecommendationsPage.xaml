<Page x:Class="MovieApp.Pages.RecommendationsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
      Background="#141414">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Рекомендации" FontSize="26" FontWeight="Bold" Foreground="White" Margin="16,0,0,16"/>

        <TabControl Grid.Row="1" Background="#1A1A1A" BorderBrush="#2A2A2A" BorderThickness="1" SelectionChanged="TabControl_SelectionChanged">
            <TabControl.Resources>
                <!-- Стилизация вкладок -->
                <Style TargetType="TabItem">
                    <Setter Property="HeaderTemplate">
                        <Setter.Value>
                            <DataTemplate>
                                <ContentPresenter Content="{TemplateBinding Content}"/>
                            </DataTemplate>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="#AAAAAA"/>
                    <Setter Property="Padding" Value="20,12"/>
                    <Setter Property="FontSize" Value="14"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border x:Name="Border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="0,0,0,2" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter x:Name="ContentSite" ContentSource="Header" RecognizesAccessKey="True" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter TargetName="Border" Property="BorderBrush" Value="#E50914"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="False">
                                        <Setter TargetName="Border" Property="BorderBrush" Value="Transparent"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>

            <!-- Вкладка: Персональные рекомендации -->
            <TabItem x:Name="TabPersonal">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="StarCircle" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Персональные рекомендации" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- баннер алгоритма: взвешенная контентная фильтрация -->
                    <Border Grid.Row="0" Background="#1A1A1A" Padding="24,14"
                            BorderThickness="0,0,0,1" BorderBrush="#2A2A2A">
                        <StackPanel>
                            <!-- заголовок и описание метода -->
                            <TextBlock Text="Персональный подбор"
                                       FontSize="16" FontWeight="Bold" Foreground="#FFFFFF"/>
                            <TextBlock Text="Алгоритм использует взвешенную контентную фильтрацию. Чем больше оценок вы ставите, тем точнее рекомендации."
                                       FontSize="14" Foreground="#CCCCCC"
                                       TextWrapping="Wrap"
                                       Margin="0,4,0,10"/>

                            <!-- шкала весов оценок -->
                            <StackPanel Orientation="Horizontal">
                                <!-- 5 звёзд -->
                                <Border Background="#1A3A1A" CornerRadius="4" Padding="8,3" Margin="0,0,6,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="★★★★★" FontSize="11" Foreground="#4CAF50" FontWeight="SemiBold"/>
                                        <TextBlock Text=" +2.0" FontSize="11" Foreground="#4CAF50" FontWeight="Bold"/>
                                    </StackPanel>
                                </Border>

                                <!-- 4 звезды -->
                                <Border Background="#1E3A1A" CornerRadius="4" Padding="8,3" Margin="0,0,6,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="★★★★☆" FontSize="11" Foreground="#8BC34A" FontWeight="SemiBold"/>
                                        <TextBlock Text=" +1.0" FontSize="11" Foreground="#8BC34A" FontWeight="Bold"/>
                                    </StackPanel>
                                </Border>

                                <!-- 3 звезды -->
                                <Border Background="#2A2A2A" CornerRadius="4" Padding="8,3" Margin="0,0,6,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="★★★☆☆" FontSize="11" Foreground="#6B6B6B" FontWeight="SemiBold"/>
                                        <TextBlock Text=" 0" FontSize="11" Foreground="#6B6B6B" FontWeight="Bold"/>
                                    </StackPanel>
                                </Border>

                                <!-- 2 звезды -->
                                <Border Background="#3A1A1A" CornerRadius="4" Padding="8,3" Margin="0,0,6,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="★★☆☆☆" FontSize="11" Foreground="#FF7043" FontWeight="SemiBold"/>
                                        <TextBlock Text=" −1.0" FontSize="11" Foreground="#FF7043" FontWeight="Bold"/>
                                    </StackPanel>
                                </Border>

                                <!-- 1 звезда -->
                                <Border Background="#3A1010" CornerRadius="4" Padding="8,3" Margin="0,0,12,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="★☆☆☆☆" FontSize="11" Foreground="#E50914" FontWeight="SemiBold"/>
                                        <TextBlock Text=" −2.0" FontSize="11" Foreground="#E50914" FontWeight="Bold"/>
                                    </StackPanel>
                                </Border>

                                <!-- разделитель -->
                                <Rectangle Width="1" Height="16" Fill="#333333" VerticalAlignment="Center" Margin="0,0,12,0"/>

                                <!-- бонус качества -->
                                <Border Background="#1A1A2E" CornerRadius="4" Padding="8,3">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <iconPacks:PackIconMaterial Kind="Star" Width="11" Height="11" Foreground="#7986CB" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                        <TextBlock Text="Рейтинг КП" FontSize="11" Foreground="#7986CB" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        <TextBlock Text=" × 0.5" FontSize="11" Foreground="#7986CB" FontWeight="Bold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <!-- индикатор загрузки -->
                            <StackPanel x:Name="PanelLoading" HorizontalAlignment="Center" Margin="0,60,0,0">
                                <iconPacks:PackIconMaterial Kind="TimerSand" Width="48" Height="48" Foreground="#6B6B6B" HorizontalAlignment="Center"/>
                                <TextBlock Text="Формируем рекомендации..."
                                           FontSize="18" Foreground="#CCCCCC"
                                           HorizontalAlignment="Center" Margin="0,12,0,0"/>
                            </StackPanel>

                            <!-- пустое состояние — нет оценок -->
                            <StackPanel x:Name="PanelNoRatings"
                                        HorizontalAlignment="Center"
                                        Margin="0,60,0,0"
                                        Visibility="Collapsed">
                                <iconPacks:PackIconMaterial Kind="StarCircle" Width="64" Height="64" Foreground="#6B6B6B" HorizontalAlignment="Center"/>
                                <TextBlock Text="Пока нет данных для рекомендаций"
                                           FontSize="20" FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           Margin="0,16,0,8"/>
                                <TextBlock Text="Оцените хотя бы несколько фильмов на 4 или 5 звёзд"
                                           FontSize="16" Foreground="#CCCCCC"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>

                            <!-- счётчик -->
                            <TextBlock x:Name="TxtCount"
                                       Text=""
                                       FontSize="15" Foreground="#CCCCCC"
                                       Margin="24,16,24,8"
                                       Visibility="Collapsed"/>

                            <!-- сетка рекомендованных карточек -->
                            <ItemsControl x:Name="RecPanel" Margin="16,0,16,16">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="168" Margin="8"
                                                Background="#1F1F1F"
                                                CornerRadius="8"
                                                Cursor="Hand"
                                                Tag="{Binding Id}"
                                                MouseLeftButtonDown="OnMovieCardClicked">
                                            <Border.Effect>
                                                <DropShadowEffect Color="#000000" BlurRadius="12" Opacity="0.4" ShadowDepth="2"/>
                                            </Border.Effect>
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="230"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <!-- постер: заглушка 🎬 + кэшированное изображение из LocalPosterPath -->
                                                <Border Grid.Row="0" CornerRadius="8,8,0,0" ClipToBounds="True">
                                                    <Grid>
                                                        <!-- заглушка: видна пока LocalPosterPath пуст -->
                                                        <Border Background="#2A2A2A">
                                                            <iconPacks:PackIconMaterial Kind="Movie" Width="48" Height="48"
                                                                                       Foreground="#555555"
                                                                                       HorizontalAlignment="Center"
                                                                                       VerticalAlignment="Center"/>
                                                        </Border>
                                                        <!-- постер из кэша -->
                                                        <Image Source="{Binding LocalPosterPath}"
                                                               Stretch="UniformToFill"
                                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                                    </Grid>
                                                </Border>

                                                <TextBlock Grid.Row="1"
                                                           Text="{Binding Title}"
                                                           FontSize="13" FontWeight="SemiBold"
                                                           Foreground="#FFFFFF"
                                                           Margin="10,8,10,2"
                                                           TextWrapping="Wrap"
                                                           MaxHeight="40"/>

                                                <Grid Grid.Row="2" Margin="10,0,10,10">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding Year}"
                                                               FontSize="14" Foreground="#CCCCCC"
                                                               VerticalAlignment="Center"/>
                                                    <!-- метка совпадения -->
                                                    <Border Grid.Column="1"
                                                            Background="#E50914"
                                                            CornerRadius="4"
                                                            Padding="4,2">
                                                        <TextBlock Text="Rec" FontSize="10"
                                                                   FontWeight="Bold"
                                                                   Foreground="#FFFFFF"/>
                                                    </Border>
                                                </Grid>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <!-- Вкладка: Популярное у друзей -->
            <TabItem x:Name="TabFriendsPopular">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="AccountMultiple" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Популярное у друзей" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- баннер -->
                    <Border Grid.Row="0" Background="#1A1A1A" Padding="24,14"
                            BorderThickness="0,0,0,1" BorderBrush="#2A2A2A">
                        <StackPanel>
                            <TextBlock Text="Популярное у друзей"
                                       FontSize="16" FontWeight="Bold" Foreground="#FFFFFF"/>
                            <TextBlock Text="Фильмы с высокими оценками (4 и 5 звезд) от ваших друзей, которые вы еще не оценивали."
                                       FontSize="14" Foreground="#CCCCCC"
                                       TextWrapping="Wrap"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <!-- индикатор загрузки -->
                            <StackPanel x:Name="PanelFriendsPopularLoading" HorizontalAlignment="Center" Margin="0,60,0,0" Visibility="Collapsed">
                                <iconPacks:PackIconMaterial Kind="TimerSand" Width="48" Height="48" Foreground="#6B6B6B" HorizontalAlignment="Center"/>
                                <TextBlock Text="Загрузка фильмов..."
                                           FontSize="18" Foreground="#CCCCCC"
                                           HorizontalAlignment="Center" Margin="0,12,0,0"/>
                            </StackPanel>

                            <!-- пустое состояние -->
                            <StackPanel x:Name="PanelNoFriendsPopular"
                                        HorizontalAlignment="Center"
                                        Margin="0,60,0,0"
                                        Visibility="Collapsed">
                                <iconPacks:PackIconMaterial Kind="AccountQuestion" Width="64" Height="64" Foreground="#6B6B6B" HorizontalAlignment="Center"/>
                                <TextBlock Text="Нет рекомендаций от друзей"
                                           FontSize="20" FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           Margin="0,16,0,8"/>
                                <TextBlock Text="Добавьте друзей или попросите их оценить фильмы."
                                           FontSize="16" Foreground="#CCCCCC"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>

                            <!-- счётчик -->
                            <TextBlock x:Name="TxtFriendsPopularCount"
                                       Text=""
                                       FontSize="15" Foreground="#CCCCCC"
                                       Margin="24,16,24,8"
                                       Visibility="Collapsed"/>

                            <!-- сетка карточек -->
                            <ItemsControl x:Name="FriendsPopularPanel" Margin="16,0,16,16">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="168" Margin="8"
                                                Background="#1F1F1F"
                                                CornerRadius="8"
                                                Cursor="Hand"
                                                Tag="{Binding Id}"
                                                MouseLeftButtonDown="OnMovieCardClicked">
                                            <Border.Effect>
                                                <DropShadowEffect Color="#000000" BlurRadius="12" Opacity="0.4" ShadowDepth="2"/>
                                            </Border.Effect>
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="230"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <!-- постер -->
                                                <Border Grid.Row="0" CornerRadius="8,8,0,0" ClipToBounds="True">
                                                    <Grid>
                                                        <Border Background="#2A2A2A">
                                                            <iconPacks:PackIconMaterial Kind="Movie" Width="48" Height="48"
                                                                                       Foreground="#555555"
                                                                                       HorizontalAlignment="Center"
                                                                                       VerticalAlignment="Center"/>
                                                        </Border>
                                                        <Image Source="{Binding LocalPosterPath}"
                                                               Stretch="UniformToFill"
                                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                                    </Grid>
                                                </Border>

                                                <TextBlock Grid.Row="1"
                                                           Text="{Binding Title}"
                                                           FontSize="13" FontWeight="SemiBold"
                                                           Foreground="#FFFFFF"
                                                           Margin="10,8,10,2"
                                                           TextWrapping="Wrap"
                                                           MaxHeight="40"/>

                                                <Grid Grid.Row="2" Margin="10,0,10,10">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding Year}"
                                                               FontSize="14" Foreground="#CCCCCC"
                                                               VerticalAlignment="Center"/>
                                                    <Border Grid.Column="1"
                                                            Background="#0078D7"
                                                            CornerRadius="4"
                                                            Padding="4,2">
                                                        <TextBlock Text="Friend" FontSize="10"
                                                                   FontWeight="Bold"
                                                                   Foreground="#FFFFFF"/>
                                                    </Border>
                                                </Grid>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Page>

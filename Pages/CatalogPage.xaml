<Page x:Class="MovieApp.Pages.CatalogPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#141414">


    <!--
        Корневая сетка: 3 строки
        Row 0 = Auto — панель поиска
        Row 1 = *    — список карточек (ограничивает высоту ScrollViewer)
        Row 2 = Auto — подвал пагинации
    -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ══ Row 0: Панель поиска и фильтры ═════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="#1A1A1A"
                BorderBrush="#272727"
                BorderThickness="0,0,0,1"
                Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Поиск -->
                <Grid Grid.Column="0">
                    <!-- Иконка лупы -->
                    <TextBlock Text="🔍"
                               FontSize="15"
                               Foreground="#4A4A4A"
                               VerticalAlignment="Center"
                               Margin="10,0,0,0"
                               IsHitTestVisible="False"
                               Panel.ZIndex="1"/>
                    <!-- Поле ввода -->
                    <TextBox x:Name="SearchBox"
                             Background="#242424"
                             Foreground="#FFFFFF"
                             CaretBrush="#E50914"
                             FontFamily="Segoe UI"
                             FontSize="14"
                             BorderThickness="0"
                             Padding="36,9,12,9"
                             VerticalContentAlignment="Center"
                             TextChanged="SearchBox_TextChanged">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TextBox">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="8"
                                                    BorderThickness="0">
                                                <ScrollViewer x:Name="PART_ContentHost"
                                                              Margin="{TemplateBinding Padding}"
                                                              VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                    <!-- Плейсхолдер (скрывается при вводе) -->
                    <TextBlock x:Name="SearchPlaceholder"
                               Text="Поиск фильма..."
                               FontFamily="Segoe UI"
                               FontSize="14"
                               Foreground="#4A4A4A"
                               VerticalAlignment="Center"
                               Margin="36,0,0,0"
                               IsHitTestVisible="False"
                               Panel.ZIndex="1"/>
                </Grid>

                <!-- Жанры -->
                <ComboBox x:Name="CmbGenre"
                          Grid.Column="1"
                          Width="150"
                          Margin="12,0,0,0"
                          Background="#242424"
                          Foreground="#FFFFFF"
                          BorderThickness="0"
                          VerticalContentAlignment="Center"
                          SelectionChanged="CmbFilter_SelectionChanged"/>

                <!-- Тип видео -->
                <ComboBox x:Name="CmbType"
                          Grid.Column="2"
                          Width="150"
                          Margin="12,0,0,0"
                          Background="#242424"
                          Foreground="#FFFFFF"
                          BorderThickness="0"
                          VerticalContentAlignment="Center"
                          SelectionChanged="CmbFilter_SelectionChanged"/>

                <!-- Сортировка -->
                <ComboBox x:Name="CmbSort"
                          Grid.Column="3"
                          Width="180"
                          Margin="12,0,0,0"
                          Background="#242424"
                          Foreground="#FFFFFF"
                          BorderThickness="0"
                          VerticalContentAlignment="Center"
                          SelectionChanged="CmbFilter_SelectionChanged"/>
            </Grid>
        </Border>

        <!-- ══ Row 1: Список карточек фильмов ═══════════════════════════════ -->
        <ScrollViewer x:Name="MainScrollViewer"
                      Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      CanContentScroll="False">
            <StackPanel>

                <!-- счётчик результатов -->
                <TextBlock x:Name="TxtCount"
                           Text="Загрузка..."
                           FontSize="13"
                           Foreground="#4A4A4A"
                           Margin="20,14,20,8"/>

                <!-- сетка карточек: 20 штук на страницу, по центру -->
                <ItemsControl x:Name="MoviesPanel" Margin="12,0,12,16">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>

                            <!-- ══ Карточка фильма ══════════════════════════ -->
                            <Border Width="168" Margin="8"
                                    CornerRadius="8" Cursor="Hand"
                                    Tag="{Binding Id}"
                                    MouseLeftButtonDown="OnMovieCardClicked">
                                <Border.Background>
                                    <SolidColorBrush Color="#1F1F1F"/>
                                </Border.Background>
                                <Border.Effect>
                                    <DropShadowEffect Color="#000000" BlurRadius="14"
                                                      Opacity="0.5" ShadowDepth="3"/>
                                </Border.Effect>
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#272727"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>

                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="230"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- постер из локального кэша -->
                                    <Border Grid.Row="0" CornerRadius="8,8,0,0" ClipToBounds="True">
                                        <Image Source="{Binding LocalPosterPath}"
                                               Stretch="UniformToFill"
                                               RenderOptions.BitmapScalingMode="HighQuality">
                                            <Image.Style>
                                                <Style TargetType="Image">
                                                    <Style.Triggers>
                                                        <Trigger Property="Source" Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Image.Style>
                                        </Image>
                                    </Border>

                                    <!-- заглушка 🎬 если постера нет -->
                                    <Border Grid.Row="0" Background="#252525"
                                            CornerRadius="8,8,0,0"
                                            Visibility="{Binding HasNoPoster,
                                                Converter={StaticResource BoolToVisibilityConverter}}">
                                        <TextBlock Text="🎬" FontSize="48"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>

                                    <!-- название фильма -->
                                    <TextBlock Grid.Row="1"
                                               Text="{Binding Title}"
                                               FontSize="13" FontWeight="SemiBold"
                                               Foreground="#FFFFFF"
                                               Margin="10,8,10,2"
                                               TextWrapping="Wrap"
                                               MaxHeight="40"
                                               TextTrimming="CharacterEllipsis"/>

                                    <!-- год + кнопка «Оценить» + Popup -->
                                    <Grid Grid.Row="2" Margin="10,4,10,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="{Binding Year}"
                                                   FontSize="12" Foreground="#5A5A5A"
                                                   VerticalAlignment="Center"/>

                                        <!-- контейнер: кнопка «Оценить» + Popup рядом -->
                                        <Grid Grid.Column="1">

                                            <!-- кнопка «Оценить» -->
                                            <Button x:Name="BtnRate"
                                                    Content="Оценить"
                                                    FontSize="11" FontFamily="Segoe UI"
                                                    FontWeight="SemiBold"
                                                    Foreground="#FFFFFF" Background="#E50914"
                                                    BorderThickness="0" Padding="6,3"
                                                    Cursor="Hand"
                                                    Tag="{Binding Id}"
                                                    Click="BtnRate_Click">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border x:Name="BtnBorder" Background="#E50914" CornerRadius="4" Padding="6,3">
                                                                        <TextBlock x:Name="BtnText" Text="Оценить" Foreground="#FFFFFF" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <DataTrigger Binding="{Binding IsRated}" Value="True">
                                                                            <Setter TargetName="BtnBorder" Property="Background" Value="#555555"/>
                                                                            <Setter TargetName="BtnText" Property="Text" Value="Оценено"/>
                                                                            <Setter TargetName="BtnText" Property="Foreground" Value="#AAAAAA"/>
                                                                            <Setter Property="IsHitTestVisible" Value="False"/>
                                                                        </DataTrigger>
                                                                        <MultiDataTrigger>
                                                                            <MultiDataTrigger.Conditions>
                                                                                <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True"/>
                                                                                <Condition Binding="{Binding IsRated}" Value="False"/>
                                                                            </MultiDataTrigger.Conditions>
                                                                            <Setter TargetName="BtnBorder" Property="Background" Value="#FF1E27"/>
                                                                        </MultiDataTrigger>
                                                                        <MultiDataTrigger>
                                                                            <MultiDataTrigger.Conditions>
                                                                                <Condition Binding="{Binding IsPressed, RelativeSource={RelativeSource Self}}" Value="True"/>
                                                                                <Condition Binding="{Binding IsRated}" Value="False"/>
                                                                            </MultiDataTrigger.Conditions>
                                                                            <Setter TargetName="BtnBorder" Property="Background" Value="#C0000D"/>
                                                                        </MultiDataTrigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </Button.Style>
                                            </Button>

                                            <!--
                                                ══ Popup с оценкой ══════════════════════════════
                                                КЛЮЧЕВОЕ ИСПРАВЛЕНИЕ:
                                                DataContext="{Binding PlacementTarget.DataContext,
                                                    RelativeSource={RelativeSource Self}}"

                                                Popup живёт в отдельном визуальном дереве и теряет
                                                DataContext из DataTemplate. Привязываем DataContext
                                                к DataContext кнопки BtnRate (= MovieViewModel).
                                                Теперь Tag="{Binding Id}" внутри Popup работает.
                                            ═══════════════════════════════════════════════════ -->
                                            <Popup x:Name="RatingPopup"
                                                   PlacementTarget="{Binding ElementName=BtnRate}"
                                                   DataContext="{Binding PlacementTarget.DataContext,
                                                       RelativeSource={RelativeSource Self}}"
                                                   Placement="Top"
                                                   StaysOpen="False"
                                                   AllowsTransparency="True"
                                                   PopupAnimation="Fade">
                                                <Border Background="#1A1A1A"
                                                        BorderBrush="#333333"
                                                        BorderThickness="1"
                                                        CornerRadius="10"
                                                        Padding="12,10"
                                                        MinWidth="190">
                                                    <Border.Effect>
                                                        <DropShadowEffect Color="#000000"
                                                                          BlurRadius="20"
                                                                          Opacity="0.7"
                                                                          ShadowDepth="4"/>
                                                    </Border.Effect>
                                                    <StackPanel>

                                                        <!-- заголовок попапа -->
                                                        <TextBlock Text="Ваша оценка"
                                                                   FontSize="11"
                                                                   FontFamily="Segoe UI"
                                                                   Foreground="#6B6B6B"
                                                                   HorizontalAlignment="Center"
                                                                   Margin="0,0,0,8"/>

                                                        <!--
                                                            5 звёзд — Tag="{Binding Id}" теперь
                                                            получает реальный Id фильма, т.к.
                                                            DataContext унаследован от Popup
                                                        -->
                                                        <StackPanel Orientation="Horizontal"
                                                                    HorizontalAlignment="Center">
                                                            <Button Content="★" FontSize="24"
                                                                    Foreground="#444444"
                                                                    Background="Transparent"
                                                                    BorderThickness="0" Padding="4"
                                                                    Cursor="Hand"
                                                                    CommandParameter="1"
                                                                    Tag="{Binding Id}"
                                                                    Click="StarButton_Click"/>
                                                            <Button Content="★" FontSize="24"
                                                                    Foreground="#444444"
                                                                    Background="Transparent"
                                                                    BorderThickness="0" Padding="4"
                                                                    Cursor="Hand"
                                                                    CommandParameter="2"
                                                                    Tag="{Binding Id}"
                                                                    Click="StarButton_Click"/>
                                                            <Button Content="★" FontSize="24"
                                                                    Foreground="#444444"
                                                                    Background="Transparent"
                                                                    BorderThickness="0" Padding="4"
                                                                    Cursor="Hand"
                                                                    CommandParameter="3"
                                                                    Tag="{Binding Id}"
                                                                    Click="StarButton_Click"/>
                                                            <Button Content="★" FontSize="24"
                                                                    Foreground="#444444"
                                                                    Background="Transparent"
                                                                    BorderThickness="0" Padding="4"
                                                                    Cursor="Hand"
                                                                    CommandParameter="4"
                                                                    Tag="{Binding Id}"
                                                                    Click="StarButton_Click"/>
                                                            <Button Content="★" FontSize="24"
                                                                    Foreground="#444444"
                                                                    Background="Transparent"
                                                                    BorderThickness="0" Padding="4"
                                                                    Cursor="Hand"
                                                                    CommandParameter="5"
                                                                    Tag="{Binding Id}"
                                                                    Click="StarButton_Click"/>
                                                        </StackPanel>

                                                        <!-- сообщение об успехе (скрыто по умолчанию) -->
                                                        <TextBlock x:Name="TxtRatingSuccess"
                                                                   Text="✓  Оценка сохранена!"
                                                                   FontSize="12"
                                                                   FontFamily="Segoe UI"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#4CAF50"
                                                                   HorizontalAlignment="Center"
                                                                   Margin="0,8,0,0"
                                                                   Visibility="Collapsed"/>
                                                    </StackPanel>
                                                </Border>
                                            </Popup>

                                        </Grid>
                                    </Grid>
                                </Grid>
                            </Border>
                            <!-- ══ Конец карточки ══════════════════════════ -->

                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- заглушка: база данных пуста -->
                <StackPanel x:Name="PanelEmpty"
                            HorizontalAlignment="Center"
                            Margin="0,80,0,0"
                            Visibility="Collapsed">
                    <TextBlock Text="📭" FontSize="64" HorizontalAlignment="Center"/>
                    <TextBlock Text="База данных пуста"
                               FontSize="20" FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Margin="0,16,0,8"/>
                    <TextBlock Text="Загрузите фильмы через раздел «Администратор»"
                               FontSize="14" Foreground="#6B6B6B"
                               HorizontalAlignment="Center"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- ══ Row 2: Подвал пагинации с нумерацией страниц ═══════════════════ -->
        <Border Grid.Row="2"
                Background="#141414"
                BorderBrush="#242424"
                BorderThickness="0,1,0,0"
                Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- кнопка «Назад» -->
                <Button x:Name="BtnPrev"
                        Grid.Column="0"
                        Content="◀  Назад"
                        Width="90" Height="32" Margin="0,0,8,0"
                        FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold"
                        Foreground="#B3B3B3" Background="Transparent"
                        BorderThickness="0" Cursor="Hand"
                        IsEnabled="False"
                        Click="BtnPrev_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd"
                                                Background="{TemplateBinding Background}"
                                                CornerRadius="6"
                                                Opacity="{TemplateBinding IsEnabled,
                                                    Converter={StaticResource BoolToOpacityConverter}}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#2A2A2A"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- нумерованные кнопки страниц -->
                <ItemsControl x:Name="PageNumbersPanel"
                              Grid.Column="1"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!-- DataTrigger: активная страница → красный фон -->
                            <Button Content="{Binding Number}"
                                    Tag="{Binding Number}"
                                    Width="32" Height="32" Margin="2,0"
                                    FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold"
                                    BorderThickness="0" Cursor="Hand"
                                    Click="PageNumberButton_Click">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Foreground" Value="#B3B3B3"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Bd"
                                                            Background="{TemplateBinding Background}"
                                                            CornerRadius="6"
                                                            Width="{TemplateBinding Width}"
                                                            Height="{TemplateBinding Height}">
                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="#2A2A2A"/>
                                                            <Setter Property="Foreground" Value="#FFFFFF"/>
                                                        </Trigger>
                                                        <Trigger Property="IsPressed" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="#C0000D"/>
                                                            <Setter Property="Foreground" Value="#FFFFFF"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                <Setter Property="Background" Value="#E50914"/>
                                                <Setter Property="Foreground" Value="#FFFFFF"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- кнопка «Вперёд» -->
                <Button x:Name="BtnNext"
                        Grid.Column="2"
                        Content="Вперёд  ▶"
                        Width="90" Height="32" Margin="8,0,0,0"
                        FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold"
                        Foreground="#FFFFFF" Background="#E50914"
                        BorderThickness="0" Cursor="Hand"
                        IsEnabled="False"
                        Click="BtnNext_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd"
                                                Background="{TemplateBinding Background}"
                                                CornerRadius="6"
                                                Opacity="{TemplateBinding IsEnabled,
                                                    Converter={StaticResource BoolToOpacityConverter}}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#FF1E27"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#C0000D"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

            </Grid>
        </Border>
    </Grid>
</Page>

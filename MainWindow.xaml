<Window x:Class="MovieApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="КиноРек — Рекомендации фильмов"
        Height="750" Width="1150"
        MinHeight="650" MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundDeep}">

    <!-- корневая сетка: левый сайдбар + разделитель + правая область контента -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="1"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ===========================================
             ЛЕВАЯ КОЛОНКА — боковое навигационное меню
        =========================================== -->
        <Border Grid.Column="0" Background="{StaticResource BackgroundSidebar}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- логотип и название приложения -->
                <StackPanel Grid.Row="0" Margin="24,30,24,20">
                    <TextBlock Text="🎬" FontSize="36" Margin="0,0,0,8"/>
                    <TextBlock Text="КиноРек"
                               FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimary}"/>
                    <TextBlock Text="рекомендации фильмов"
                               FontSize="11"
                               Foreground="{StaticResource TextMuted}"
                               Margin="0,2,0,0"/>
                </StackPanel>

                <!-- горизонтальный разделитель -->
                <Rectangle Grid.Row="1" Height="1" Margin="16,0"
                           Fill="{StaticResource Separator}"/>

                <!-- кнопки навигации -->
                <StackPanel Grid.Row="2" Margin="0,16,0,0">

                    <!-- переход в каталог всех фильмов -->
                    <Button x:Name="BtnCatalog"
                            Content="🎥  Каталог"
                            Style="{StaticResource NavButtonStyle}"
                            Click="BtnCatalog_Click"/>

                    <!-- переход к просмотренным и оценённым фильмам -->
                    <Button x:Name="BtnWatched"
                            Content="✅  Просмотренные"
                            Style="{StaticResource NavButtonStyle}"
                            Click="BtnWatched_Click"
                            Margin="0,4,0,0"/>

                    <!-- переход к персональным рекомендациям -->
                    <Button x:Name="BtnRecommendations"
                            Content="⭐  Рекомендации"
                            Style="{StaticResource NavButtonStyle}"
                            Click="BtnRecommendations_Click"
                            Margin="0,4,0,0"/>

                </StackPanel>

                <!-- нижняя секция: пользователь + кнопка администратора -->
                <StackPanel Grid.Row="3" Margin="0,0,0,20">

                    <Rectangle Height="1" Margin="16,0,16,12"
                               Fill="{StaticResource Separator}"/>

                    <!-- блок с именем и ролью текущего пользователя -->
                    <StackPanel Margin="24,0,24,12" Orientation="Horizontal">
                        <Ellipse Width="28" Height="28"
                                 Fill="{StaticResource AccentRed}"/>
                        <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock x:Name="TxtUsername"
                                       Text="Пользователь"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimary}"/>
                            <TextBlock x:Name="TxtUserRole"
                                       Text="User"
                                       FontSize="11"
                                       Foreground="{StaticResource TextMuted}"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- кнопка импорта из TMDb API — только для роли Admin -->
                    <Button x:Name="BtnImportApi"
                            Content="⚙️  Импорт API"
                            Style="{StaticResource AdminButtonStyle}"
                            Click="BtnImportApi_Click"
                            Visibility="Collapsed"/>

                    <!-- переход в профиль пользователя -->
                    <Button x:Name="BtnProfile"
                            Content="👤  Профиль"
                            Style="{StaticResource NavButtonStyle}"
                            Click="BtnProfile_Click"
                            Margin="0,4,0,0"/>

                    <!-- служба поддержки -->
                    <Button x:Name="BtnNavSupport"
                            Content="🎧  Поддержка"
                            Style="{StaticResource NavButtonStyle}"
                            Click="BtnNavSupport_Click"
                            Margin="0,4,0,0"/>

                    <!-- управление контентом -->
                    <Button x:Name="BtnNavContent"
                            Content="🎬  Контент"
                            Style="{StaticResource NavButtonStyle}"
                            Click="BtnNavContent_Click"
                            Margin="0,4,0,0"/>

                    <!-- управление пользователями -->
                    <Button x:Name="BtnNavUsers"
                            Content="👥  Пользователи"
                            Style="{StaticResource NavButtonStyle}"
                            Click="BtnNavUsers_Click"
                            Margin="0,4,0,0"/>

                    <!-- жалобы от пользователей -->
                    <Button x:Name="BtnNavTickets"
                            Content="📩  Жалобы"
                            Style="{StaticResource NavButtonStyle}"
                            Click="BtnNavTickets_Click"
                            Margin="0,4,0,0"/>

                    <!-- кнопка выхода -->
                    <Button x:Name="BtnLogout"
                            Content="🚪  Выйти"
                            Style="{StaticResource NavButtonStyle}"
                            Foreground="#E50914"
                            Click="BtnLogout_Click"
                            Margin="0,4,0,0"/>

                </StackPanel>
            </Grid>
        </Border>

        <!-- вертикальный разделитель между сайдбаром и контентом -->
        <Rectangle Grid.Column="1" Fill="{StaticResource Separator}"/>

        <!-- ===========================================
             ПРАВАЯ КОЛОНКА — область контента (страницы)
        =========================================== -->
        <Grid Grid.Column="2" Background="{StaticResource BackgroundDeep}">
            <Grid.RowDefinitions>
                <!-- верхняя панель с заголовком раздела -->
                <RowDefinition Height="64"/>
                <!-- основная область контента -->
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- шапка с заголовком текущей страницы -->
            <Border Grid.Row="0"
                    Background="{StaticResource BackgroundSidebar}"
                    BorderThickness="0,0,0,1"
                    BorderBrush="{StaticResource Separator}">
                <!-- только заголовок текущего раздела, без лишних элементов -->
                <TextBlock x:Name="TxtPageTitle"
                           Text="Добро пожаловать"
                           FontSize="18" FontWeight="Bold"
                           VerticalAlignment="Center"
                           Margin="28,0"/>
            </Border>

            <!-- контейнер для загрузки страниц при навигации -->
            <Frame x:Name="MainContent" Grid.Row="1"
                   NavigationUIVisibility="Hidden"
                   Background="{StaticResource BackgroundDeep}"/>
        </Grid>
    </Grid>
</Window>

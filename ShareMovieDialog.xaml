<Window x:Class="MovieApp.ShareMovieDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        Title="Поделиться фильмом" 
        Height="350" Width="300"
        WindowStartupLocation="CenterOwner"
        Background="#141414"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Выберите друга" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,0,0,12"/>

        <Border Grid.Row="1" Background="#1A1A1A" BorderBrush="#2A2A2A" BorderThickness="1" CornerRadius="4" Padding="4">
            <Grid>
                <TextBlock x:Name="TxtNoFriends" Text="У вас пока нет друзей." Foreground="#888888" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>
                <ListBox x:Name="LbFriends" Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="8,6"/>
                            <Setter Property="Margin" Value="0,1"/>
                            <Setter Property="Background" Value="#1F1F1F"/>
                            <Style.Resources>
                                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#E50914"/>
                                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White"/>
                            </Style.Resources>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Ellipse Grid.Column="0" Width="24" Height="24" Fill="#333333" Margin="0,0,8,0"/>
                                <TextBlock Grid.Column="0" Text="{Binding Initials}" Foreground="White" FontWeight="Bold" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Grid.Column="1" Text="{Binding Login}" FontSize="13" Foreground="White" VerticalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Style="{x:Null}" Content="Отмена" Width="90" Click="BtnCancel_Click" Padding="8,4" Background="#2A2A2A" Foreground="White" BorderThickness="1" BorderBrush="#444444" Margin="0,0,10,0" Cursor="Hand"/>
            <Button Style="{x:Null}" Content="Отправить" Width="90" Click="BtnSend_Click" Padding="8,4" Background="#E50914" Foreground="White" BorderThickness="0" FontWeight="SemiBold" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>

<Window x:Class="MovieApp.RateMovieDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Оценить фильм"
        Height="260" Width="360"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#1F1F1F">

    <StackPanel Margin="32">
        <TextBlock Text="Ваша оценка" Foreground="#B3B3B3" FontSize="12" Margin="0,0,0,6"/>
        <TextBlock x:Name="TxtMovieName"
                   Text=""
                   FontSize="15" FontWeight="SemiBold"
                   Foreground="#FFFFFF"
                   TextWrapping="Wrap"
                   Margin="0,0,0,20"/>

        <!-- звёзды выбора оценки -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,24">
            <Button x:Name="Star1" Content="★" FontSize="28" Tag="1" Style="{StaticResource StarButtonStyle}" Click="Star_Click"/>
            <Button x:Name="Star2" Content="★" FontSize="28" Tag="2" Style="{StaticResource StarButtonStyle}" Click="Star_Click"/>
            <Button x:Name="Star3" Content="★" FontSize="28" Tag="3" Style="{StaticResource StarButtonStyle}" Click="Star_Click"/>
            <Button x:Name="Star4" Content="★" FontSize="28" Tag="4" Style="{StaticResource StarButtonStyle}" Click="Star_Click"/>
            <Button x:Name="Star5" Content="★" FontSize="28" Tag="5" Style="{StaticResource StarButtonStyle}" Click="Star_Click"/>
        </StackPanel>

        <TextBlock x:Name="TxtSelected"
                   Text="Выберите оценку"
                   Foreground="#6B6B6B"
                   FontSize="13"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"/>

        <Button x:Name="BtnSave"
                Content="Сохранить оценку"
                Style="{StaticResource PrimaryButtonStyle}"
                Height="40"
                Click="BtnSave_Click"
                IsEnabled="False"/>
    </StackPanel>
</Window>

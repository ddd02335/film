<Window x:Class="MovieApp.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Регистрация — КиноРек"
        Height="600" Width="350"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#141414">

    <!-- Глобальные стили для кнопок, чтобы убрать стандартную белую рамку и добавить hover -->
    <Window.Resources>
        <Style TargetType="Button" x:Key="SolidButtonStyle">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FF1E27"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#C0000D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="TransparentButtonStyle">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Title -->
            <RowDefinition Height="Auto"/> <!-- Login -->
            <RowDefinition Height="Auto"/> <!-- Password -->
            <RowDefinition Height="Auto"/> <!-- Confirm Password -->
            <RowDefinition Height="Auto"/> <!-- Error Message -->
            <RowDefinition Height="*"/>    <!-- Spacing -->
            <RowDefinition Height="Auto"/> <!-- Register Button -->
            <RowDefinition Height="Auto"/> <!-- Back Button -->
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" Text="Регистрация" 
                   Foreground="White" FontSize="24" FontFamily="Segoe UI" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,25"/>

        <!-- Логин -->
        <StackPanel Grid.Row="1" Margin="0,0,0,15">
            <TextBlock Text="Логин" Foreground="#B3B3B3" FontFamily="Segoe UI" FontSize="14" Margin="0,0,0,5"/>
            <Border Background="#2A2A2A" CornerRadius="4" Height="38">
                <TextBox x:Name="TxtLogin" 
                         Background="Transparent" Foreground="White" FontFamily="Segoe UI" FontSize="14" 
                         BorderThickness="0" VerticalContentAlignment="Center" Padding="10,0"/>
            </Border>
        </StackPanel>

        <!-- Пароль -->
        <StackPanel Grid.Row="2" Margin="0,0,0,15">
            <TextBlock Text="Пароль" Foreground="#B3B3B3" FontFamily="Segoe UI" FontSize="14" Margin="0,0,0,5"/>
            <Border Background="#2A2A2A" CornerRadius="4" Height="38">
                <Grid>
                    <PasswordBox x:Name="TxtPassword" 
                                 Background="Transparent" Foreground="White" FontFamily="Segoe UI" FontSize="14" 
                                 BorderThickness="0" VerticalContentAlignment="Center" Padding="10,0"
                                 PasswordChanged="TxtPassword_PasswordChanged"/>
                    <TextBox x:Name="TxtPasswordVisible"
                             Background="Transparent" Foreground="White" FontFamily="Segoe UI" FontSize="14"
                             BorderThickness="0" VerticalContentAlignment="Center" Padding="10,0"
                             Visibility="Collapsed"
                             TextChanged="TxtPasswordVisible_TextChanged"/>
                </Grid>
            </Border>
        </StackPanel>

        <!-- Повторите пароль -->
        <StackPanel Grid.Row="3" Margin="0,0,0,10">
            <TextBlock Text="Повторите пароль" Foreground="#B3B3B3" FontFamily="Segoe UI" FontSize="14" Margin="0,0,0,5"/>
            <Border Background="#2A2A2A" CornerRadius="4" Height="38">
                <Grid>
                    <PasswordBox x:Name="TxtConfirmPassword" 
                                 Background="Transparent" Foreground="White" FontFamily="Segoe UI" FontSize="14" 
                                 BorderThickness="0" VerticalContentAlignment="Center" Padding="10,0"
                                 PasswordChanged="TxtConfirmPassword_PasswordChanged"/>
                    <TextBox x:Name="TxtConfirmPasswordVisible"
                             Background="Transparent" Foreground="White" FontFamily="Segoe UI" FontSize="14"
                             BorderThickness="0" VerticalContentAlignment="Center" Padding="10,0"
                             Visibility="Collapsed"
                             TextChanged="TxtConfirmPasswordVisible_TextChanged"/>
                </Grid>
            </Border>
        </StackPanel>

        <!-- чекбокс: показать пароль -->
        <CheckBox x:Name="ChkShowPassword"
                  Grid.Row="4"
                  Content="Показать пароль"
                  Foreground="#B3B3B3"
                  FontSize="12"
                  Margin="0,0,0,10"
                  Checked="ChkShowPassword_Checked"
                  Unchecked="ChkShowPassword_Unchecked"/>

        <!-- Ошибка -->
        <TextBlock x:Name="TxtError" Grid.Row="5" Text="" 
                   Foreground="#E50914" FontFamily="Segoe UI" FontSize="13" TextWrapping="Wrap" 
                   HorizontalAlignment="Center" Margin="0,5,0,10" Visibility="Collapsed"/>

        <!-- Кнопка регистрации -->
        <Button x:Name="BtnRegister" Grid.Row="6" Content="Зарегистрироваться" 
                Height="42" Background="#E50914" Foreground="White" 
                FontFamily="Segoe UI" FontSize="14" FontWeight="SemiBold" 
                Cursor="Hand" Margin="0,0,0,12"
                Style="{StaticResource SolidButtonStyle}"
                Click="BtnRegister_Click"/>

        <!-- Назад ко входу -->
        <Button x:Name="BtnBack" Grid.Row="7" Content="Назад ко входу" 
                Height="30" Foreground="#B3B3B3" 
                FontFamily="Segoe UI" FontSize="13"
                Cursor="Hand"
                Style="{StaticResource TransparentButtonStyle}"
                Click="BtnBack_Click"/>
    </Grid>
</Window>

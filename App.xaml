<Application x:Class="MovieApp.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:MovieApp"
             DispatcherUnhandledException="Application_DispatcherUnhandledException">
    <Application.Resources>

        <!-- конвертер bool → Visibility (True=Visible, False=Collapsed) -->
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <!-- конвертер bool → Opacity (True=1.0, False=0.4) для кнопок пагинации -->
        <local:BoolToOpacityConverter x:Key="BoolToOpacityConverter"/>

        <!-- конвертер bool → Style для кнопки номера страницы (активная/обычная) -->
        <local:BoolToPageButtonStyleConverter x:Key="BoolToPageButtonStyleConverter"/>

        <!-- =============================================
             цветовая палитра — "тёмная кинотека"
        ============================================= -->
        <SolidColorBrush x:Key="BackgroundDeep"    Color="#141414"/>
        <SolidColorBrush x:Key="BackgroundSidebar" Color="#1F1F1F"/>
        <SolidColorBrush x:Key="BackgroundCard"    Color="#2A2A2A"/>
        <SolidColorBrush x:Key="AccentRed"         Color="#E50914"/>
        <SolidColorBrush x:Key="AccentRedHover"    Color="#FF1E27"/>
        <SolidColorBrush x:Key="AccentOrange"      Color="#FFA500"/>
        <SolidColorBrush x:Key="TextPrimary"       Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextSecondary"     Color="#B3B3B3"/>
        <SolidColorBrush x:Key="TextMuted"         Color="#6B6B6B"/>
        <SolidColorBrush x:Key="Separator"         Color="#2A2A2A"/>

        <!-- =============================================
             СТЕЛС-СКРОЛЛБАР: тонкий, тёмный, сливается с фоном #141414
             Глобальный стиль, применяется ко всем ScrollViewer в приложении.
        ============================================= -->
        <Style x:Key="StealthThumb" TargetType="Thumb">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThumbBorder" Background="#2E2E2E"
                                CornerRadius="2.5" Margin="1,2"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="#E50914"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="#C0000D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StealthRepeatButton" TargetType="RepeatButton">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Focusable"             Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent" Width="0" Height="0"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <ControlTemplate x:Key="StealthScrollBarTpl" TargetType="ScrollBar">
            <Border Background="#181818" Width="5" CornerRadius="2.5">
                <Track x:Name="PART_Track" IsDirectionReversed="True">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Style="{StaticResource StealthRepeatButton}"
                                      Command="ScrollBar.PageUpCommand"/>
                    </Track.DecreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb Style="{StaticResource StealthThumb}"/>
                    </Track.Thumb>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Style="{StaticResource StealthRepeatButton}"
                                      Command="ScrollBar.PageDownCommand"/>
                    </Track.IncreaseRepeatButton>
                </Track>
            </Border>
        </ControlTemplate>

        <Style TargetType="ScrollBar">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="SnapsToDevicePixels"   Value="True"/>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="Width"    Value="5"/>
                    <Setter Property="Template" Value="{StaticResource StealthScrollBarTpl}"/>
                </Trigger>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Height"     Value="0"/>
                    <Setter Property="Visibility" Value="Collapsed"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- =============================================
             глобальный стиль для TextBlock
        ============================================= -->
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize"   Value="14"/>
        </Style>

        <!-- =============================================
             стиль кнопки навигационного меню
        ============================================= -->
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background"             Value="Transparent"/>
            <Setter Property="Foreground"             Value="{StaticResource TextSecondary}"/>
            <Setter Property="FontFamily"             Value="Segoe UI"/>
            <Setter Property="FontSize"               Value="15"/>
            <Setter Property="FontWeight"             Value="SemiBold"/>
            <Setter Property="Height"                 Value="48"/>
            <Setter Property="Cursor"                 Value="Hand"/>
            <Setter Property="BorderThickness"        Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding"                Value="24,0,0,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <!-- левая красная полоса появляется при наведении -->
                        <Border x:Name="RootBorder"
                                Background="{TemplateBinding Background}"
                                BorderThickness="3,0,0,0"
                                BorderBrush="Transparent">
                            <ContentPresenter VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder" Property="Background"  Value="#2A2A2A"/>
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="{StaticResource AccentRed}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="#333333"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- =============================================
             главная акцентная кнопка (красный фон)
        ============================================= -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource AccentRed}"/>
            <Setter Property="Foreground"      Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Padding"         Value="20,10"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="RootBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder" Property="Background"
                                        Value="{StaticResource AccentRedHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="#C0000D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- =============================================
             кнопка администратора (оранжевый акцент)
        ============================================= -->
        <Style x:Key="AdminButtonStyle" TargetType="Button"
               BasedOn="{StaticResource NavButtonStyle}">
            <Setter Property="Foreground" Value="{StaticResource AccentOrange}"/>
        </Style>

        <!-- =============================================
             стиль кнопки-звезды для диалога оценки
        ============================================= -->
        <Style x:Key="StarButtonStyle" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#444444"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Padding"         Value="2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <TextBlock Text="{TemplateBinding Content}"
                                   Foreground="{TemplateBinding Foreground}"
                                   FontSize="{TemplateBinding FontSize}"
                                   Padding="{TemplateBinding Padding}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- =============================================
             ТЁМНАЯ ТЕМА: ComboBox — полное переопределение
             Уничтожает все белые/серые системные цвета Windows.
        ============================================= -->

        <!-- ToggleButton внутри ComboBox: тёмный фон, кастомная стрелка -->
        <Style x:Key="DarkComboBoxToggleButton" TargetType="ToggleButton">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Focusable"             Value="False"/>
            <Setter Property="Cursor"                Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="ToggleBorder"
                                Background="#1A1A1A"
                                BorderBrush="#333333"
                                BorderThickness="1"
                                CornerRadius="4">
                            <Grid>
                                <!-- область для текста выбранного элемента -->
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="28"/>
                                </Grid.ColumnDefinitions>
                                <!-- пустая область — текст рендерит сам ComboBox -->
                                <Border Grid.Column="0" Background="Transparent"/>
                                <!-- область стрелки -->
                                <Border Grid.Column="1" Background="Transparent">
                                    <Path x:Name="Arrow"
                                          Data="M 0 0 L 5 5 L 10 0 Z"
                                          Fill="#B3B3B3"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Width="10" Height="6"
                                          Stretch="Uniform"/>
                                </Border>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <!-- наведение мыши -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="#E50914"/>
                                <Setter TargetName="Arrow"        Property="Fill"        Value="#E50914"/>
                            </Trigger>
                            <!-- дропдаун открыт -->
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ToggleBorder" Property="BorderBrush"    Value="#E50914"/>
                                <Setter TargetName="ToggleBorder" Property="Background"     Value="#222222"/>
                                <Setter TargetName="ToggleBorder" Property="CornerRadius"   Value="4,4,0,0"/>
                                <Setter TargetName="Arrow"        Property="Fill"           Value="#E50914"/>
                                <!-- стрелка вверх когда открыто -->
                                <Setter TargetName="Arrow"        Property="Data"           Value="M 0 5 L 5 0 L 10 5 Z"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBoxItem: тёмный, с hover и selected состояниями -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="OverridesDefaultStyle"     Value="True"/>
            <Setter Property="Foreground"                Value="#FFFFFF"/>
            <Setter Property="Background"                Value="Transparent"/>
            <Setter Property="FontFamily"                Value="Segoe UI"/>
            <Setter Property="FontSize"                  Value="14"/>
            <Setter Property="Padding"                   Value="12,7"/>
            <Setter Property="Cursor"                    Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <!-- наведение мыши -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#333333"/>
                            </Trigger>
                            <!-- выделенный элемент -->
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#E50914"/>
                            </Trigger>
                            <!-- выделен + наведение -->
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected"    Value="True"/>
                                    <Condition Property="IsMouseOver"   Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="ItemBorder" Property="Background" Value="#FF1E27"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBox: глобальный имплицитный стиль (без x:Key) -->
        <Style TargetType="ComboBox">
            <Setter Property="OverridesDefaultStyle"     Value="True"/>
            <Setter Property="Foreground"                Value="#FFFFFF"/>
            <Setter Property="Background"                Value="#1A1A1A"/>
            <Setter Property="BorderBrush"               Value="#333333"/>
            <Setter Property="BorderThickness"           Value="1"/>
            <Setter Property="FontFamily"                Value="Segoe UI"/>
            <Setter Property="FontSize"                  Value="14"/>
            <Setter Property="Padding"                   Value="10,6"/>
            <Setter Property="Cursor"                    Value="Hand"/>
            <Setter Property="SnapsToDevicePixels"       Value="True"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility"   Value="Auto"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <!-- ToggleButton занимает всю ширину и открывает дропдаун -->
                            <ToggleButton x:Name="ToggleBtn"
                                          Style="{StaticResource DarkComboBoxToggleButton}"
                                          IsChecked="{Binding IsDropDownOpen,
                                                      Mode=TwoWay,
                                                      RelativeSource={RelativeSource TemplatedParent}}"
                                          Grid.Column="0"/>

                            <!-- отображение выбранного значения -->
                            <ContentPresenter x:Name="ContentSite"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              Margin="12,0,30,0"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"
                                              IsHitTestVisible="False"/>

                            <!-- выпадающий список -->
                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Grid x:Name="DropDown"
                                      SnapsToDevicePixels="True"
                                      MinWidth="{TemplateBinding ActualWidth}"
                                      MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder"
                                            Background="#1A1A1A"
                                            BorderBrush="#E50914"
                                            BorderThickness="1,0,1,1"
                                            CornerRadius="0,0,4,4">
                                        <ScrollViewer SnapsToDevicePixels="True">
                                            <StackPanel IsItemsHost="True"
                                                        KeyboardNavigation.DirectionalNavigation="Contained"/>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <!-- когда нет элементов — скрыть стрелку -->
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="DropDownBorder" Property="MinHeight" Value="95"/>
                            </Trigger>
                            <!-- нет выбранного значения — показать подсказку -->
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#6B6B6B"/>
                            </Trigger>
                            <!-- группировка: открытие вверх если не помещается -->
                            <Trigger Property="IsGrouping" Value="True">
                                <Setter Property="ScrollViewer.CanContentScroll" Value="False"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Application.Resources>
</Application>

<Window x:Class="MovieApp.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="КиноРек — Вход"
        Height="530" Width="400"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#141414">

    <Grid>
        <StackPanel VerticalAlignment="Center" Margin="48,0">

            <!-- логотип -->
            <TextBlock Text="🎬" FontSize="52" HorizontalAlignment="Center"/>
            <TextBlock Text="КиноРек"
                       FontSize="28" FontWeight="Bold"
                       Foreground="#FFFFFF"
                       HorizontalAlignment="Center"
                       Margin="0,8,0,4"/>
            <TextBlock Text="Войдите, чтобы продолжить"
                       FontSize="13"
                       Foreground="#6B6B6B"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,32"/>

            <!-- поле логина -->
            <TextBlock Text="Логин" Foreground="#B3B3B3" FontSize="12" Margin="0,0,0,6"/>
            <Border Background="#2A2A2A" CornerRadius="6" Margin="0,0,0,16">
                <TextBox x:Name="TxtLogin"
                         Background="Transparent"
                         Foreground="#FFFFFF"
                         FontSize="15"
                         CaretBrush="#E50914"
                         BorderThickness="0"
                         Padding="14,10"
                         FontFamily="Segoe UI"
                         KeyDown="TxtBox_KeyDown"/>
            </Border>

            <!-- поле пароля -->
            <TextBlock Text="Пароль" Foreground="#B3B3B3" FontSize="12" Margin="0,0,0,6"/>
            <Border Background="#2A2A2A" CornerRadius="6" Margin="0,0,0,8">
                <Grid>
                    <PasswordBox x:Name="TxtPassword"
                                 Background="Transparent"
                                 Foreground="#FFFFFF"
                                 FontSize="15"
                                 CaretBrush="#E50914"
                                 BorderThickness="0"
                                 Padding="14,10"
                                 FontFamily="Segoe UI"
                                 PasswordChanged="TxtPassword_PasswordChanged"
                                 KeyDown="TxtBox_KeyDown"/>
                    <TextBox x:Name="TxtPasswordVisible"
                             Background="Transparent"
                             Foreground="#FFFFFF"
                             FontSize="15"
                             CaretBrush="#E50914"
                             BorderThickness="0"
                             Padding="14,10"
                             FontFamily="Segoe UI"
                             Visibility="Collapsed"
                             TextChanged="TxtPasswordVisible_TextChanged"
                             KeyDown="TxtBox_KeyDown"/>
                </Grid>
            </Border>

            <!-- чекбокс: показать пароль -->
            <CheckBox x:Name="ChkShowPassword"
                      Content="Показать пароль"
                      Foreground="#B3B3B3"
                      FontSize="12"
                      Margin="0,0,0,16"
                      Checked="ChkShowPassword_Checked"
                      Unchecked="ChkShowPassword_Unchecked"/>

            <!-- сообщение об ошибке -->
            <TextBlock x:Name="TxtError"
                       Text=""
                       Foreground="#E50914"
                       FontSize="12"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"
                       Visibility="Collapsed"/>

            <!-- кнопка входа -->
            <Button x:Name="BtnLogin"
                    Content="Войти"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Height="44"
                    FontSize="15"
                    Click="BtnLogin_Click"/>

            <!-- переход к регистрации -->
            <Button x:Name="BtnGoToRegister"
                    Content="Нет аккаунта? Зарегистрироваться"
                    Background="Transparent"
                    Foreground="#B3B3B3"
                    BorderThickness="0"
                    FontSize="12"
                    Cursor="Hand"
                    Margin="0,16,0,0"
                    Click="BtnGoToRegister_Click"/>

        </StackPanel>
    </Grid>
</Window>

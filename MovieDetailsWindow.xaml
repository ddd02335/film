<Window x:Class="MovieApp.MovieDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        xmlns:metro="http://metro.mahapps.com/winfx/xaml/controls"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        Width="740"
        SizeToContent="Height"
        ResizeMode="NoResize">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <!-- Кнопка закрытия окна: круглая, серая, красная при наведении -->
        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="Width"           Value="32"/>
            <Setter Property="Height"          Value="32"/>
            <Setter Property="Background"      Value="#2A2A2A"/>
            <Setter Property="Foreground"      Value="#B3B3B3"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="16"
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E50914"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#C0000D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль кнопок нижней панели -->
        <Style x:Key="BottomButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!--
        Внешний Border — даёт тень и скруглённые углы для безрамочного окна.
        MouseDown="OnDragWindow" позволяет перетаскивать окно за любую область.
    -->
    <Border Background="#1A1A1A"
            CornerRadius="14"
            MouseDown="OnDragWindow"
            Margin="12">
        <Border.Effect>
            <DropShadowEffect Color="#000000"
                              BlurRadius="30"
                              Opacity="0.8"
                              ShadowDepth="0"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <!-- строка с постером + деталями -->
                <RowDefinition Height="Auto"/>
                <!-- строка с описанием -->
                <RowDefinition Height="Auto"/>
                <!-- строка с комментариями -->
                <RowDefinition Height="Auto"/>
                <!-- строка с кнопками -->
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ══ Блок: постер + детали ══════════════════════════════════════ -->
            <Grid Grid.Row="0" Margin="24,24,24,0">
                <Grid.ColumnDefinitions>
                    <!-- постер -->
                    <ColumnDefinition Width="220"/>
                    <!-- детали -->
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- постер фильма -->
                <Border Grid.Column="0"
                        CornerRadius="10"
                        ClipToBounds="True"
                        Width="220" Height="310"
                        VerticalAlignment="Top">
                    <!-- заглушка если постера нет -->
                    <Grid>
                        <Border Background="#252525">
                            <iconPacks:PackIconMaterial Kind="Movie" Width="56" Height="56"
                                                       Foreground="#555555"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                        </Border>
                        <!-- постер поверх заглушки -->
                        <Image x:Name="PosterImage"
                               Stretch="UniformToFill"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Grid>
                </Border>

                <!-- детали фильма -->
                <StackPanel Grid.Column="1"
                            Margin="24,0,0,0"
                            VerticalAlignment="Top">

                    <!-- название фильма -->
                    <TextBlock x:Name="TxtTitle"
                               Text="Название фильма"
                               FontFamily="Segoe UI"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="#FFFFFF"
                               TextWrapping="Wrap"
                               LineHeight="28"/>

                    <!-- год выпуска -->
                    <TextBlock x:Name="TxtYear"
                               Text="—"
                               FontFamily="Segoe UI"
                               FontSize="16"
                               Foreground="#CCCCCC"
                               Margin="0,8,0,0"/>

                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <!-- жанры -->
                        <Border Background="#252525"
                                CornerRadius="4"
                                Padding="8,4">
                            <TextBlock x:Name="TxtGenres"
                                       Text="Жанры не указаны"
                                       FontFamily="Segoe UI"
                                       FontSize="14"
                                       Foreground="#E0E0E0"/>
                        </Border>

                        <!-- возрастной рейтинг -->
                        <Border Background="#1A1A1A"
                                BorderBrush="#333333"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="8,4"
                                Margin="10,0,0,0">
                            <TextBlock x:Name="TxtAgeRating"
                                       Text="12+"
                                       FontFamily="Segoe UI"
                                       FontSize="12"
                                       FontWeight="Bold"
                                       Foreground="#FFFFFF"/>
                        </Border>
                    </StackPanel>

                    <!-- разделитель -->
                    <Rectangle Height="1"
                               Fill="#2A2A2A"
                               Margin="0,16,0,16"/>

                    <!-- краткая метаинформация -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="Рейтинг Кинопоиска:"
                                   FontFamily="Segoe UI"
                                   FontSize="15"
                                   Foreground="#CCCCCC"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtKpRating"
                                   Text="—"
                                   FontFamily="Segoe UI"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="#E50914"
                                   Margin="8,0,0,0"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- кнопка закрытия — в правом верхнем углу блока деталей -->
                    <Button Style="{StaticResource CloseButtonStyle}"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="0,0,0,8"
                            Click="BtnClose_Click">
                        <iconPacks:PackIconMaterial Kind="Close" Width="14" Height="14" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" VerticalAlignment="Center"/>
                        <Button.RenderTransform>
                            <TranslateTransform Y="-60"/>
                        </Button.RenderTransform>
                    </Button>

                </StackPanel>
            </Grid>

            <!-- ══ Блок: описание ══════════════════════════════════════════════ -->
            <Border Grid.Row="1"
                    Background="#141414"
                    CornerRadius="8"
                    Margin="24,20,24,0"
                    Padding="16,14">
                <StackPanel>
                    <TextBlock Text="Описание"
                               FontFamily="Segoe UI"
                               FontSize="14"
                               Foreground="#CCCCCC"
                               Margin="0,0,0,8"/>
                    <TextBlock x:Name="TxtDescription"
                               Text="Описание отсутствует."
                               FontFamily="Segoe UI"
                               FontSize="16"
                               Foreground="#F0F0F0"
                               TextWrapping="Wrap"
                               LineHeight="22"/>
                </StackPanel>
            </Border>

            <!-- ══ Блок: комментарии ══════════════════════════════════════════ -->
            <Border Grid.Row="2"
                    Background="#141414"
                    CornerRadius="8"
                    Margin="24,12,24,0"
                    Padding="16,14">
                <StackPanel>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Отзывы и комментарии"
                                   FontFamily="Segoe UI"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Foreground="#CCCCCC"
                                   VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1" x:Name="CmbSortComments" Width="160" Height="26"
                                  Background="#242424" Foreground="White" BorderBrush="#444444"
                                  VerticalContentAlignment="Center" FontSize="12"
                                  SelectionChanged="CmbSortComments_SelectionChanged">
                            <ComboBoxItem Content="Сначала новые" IsSelected="True"/>
                            <ComboBoxItem Content="Сначала старые"/>
                            <ComboBoxItem Content="С высокой оценкой"/>
                            <ComboBoxItem Content="С низкой оценкой"/>
                        </ComboBox>
                    </Grid>
                               
                    <!-- Список комментариев -->
                    <ListView x:Name="LvComments" MaxHeight="200" Background="Transparent" BorderThickness="0" Margin="0,0,0,12" ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.CanContentScroll="False">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0,6"/>
                                <Setter Property="Background" Value="Transparent"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#242424" BorderThickness="0,0,0,1" Padding="0,0,0,6" Margin="0,0,0,6">
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                             <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                 <!-- Имя автора (кнопка открытия профиля для публичных профилей) -->
                                                 <Button Style="{x:Null}" Content="{Binding UserLogin}" Click="BtnUserCommentProfile_Click" Tag="{Binding UserId}" Background="Transparent" Foreground="#E50914" BorderThickness="0" Padding="0" FontSize="13" FontWeight="Bold" Cursor="Hand" Visibility="{Binding IsNotPrivate, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                 <!-- Имя автора (текст для приватных профилей) -->
                                                 <TextBlock Text="{Binding UserLogin}" Background="Transparent" Foreground="LightGray" FontSize="13" FontWeight="Bold" VerticalAlignment="Center" Visibility="{Binding IsPrivate, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                 <!-- Оценка автора -->
                                                 <Border Background="#2A2A2A" CornerRadius="4" Padding="5,2" Margin="10,0,0,0" Visibility="{Binding RatingVisibility}">
                                                     <TextBlock Text="{Binding RatingText}" FontSize="11" Foreground="#FFD700" FontWeight="Bold"/>
                                                 </Border>
                                             </StackPanel>
                                             <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                 <!-- Кнопка удаления комментария -->
                                                 <Button Style="{x:Null}" Content="Удалить" Tag="{Binding Id}" Click="BtnDeleteCommentListItem_Click" Background="Transparent" Foreground="#E50914" BorderThickness="0" Padding="0" Margin="0,0,10,0" FontSize="11" Cursor="Hand" Visibility="{Binding DeleteVisibility}"/>
                                                 <TextBlock Text="{Binding CreatedAtText}" FontSize="11" Foreground="#666666" VerticalAlignment="Center"/>
                                             </StackPanel>
                                        </Grid>
                                        <TextBlock Text="{Binding Text}" FontSize="13" Foreground="#D0D0D0" TextWrapping="Wrap" Margin="0,4,0,0" LineHeight="18"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <!-- Ввод нового комментария -->
                    <Grid x:Name="CommentInputPanel">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="TxtNewComment" Grid.Column="0" 
                                 Background="#242424" Foreground="White" BorderBrush="#444444" BorderThickness="1" 
                                 Padding="8,6" FontSize="13" Height="34" VerticalContentAlignment="Center"
                                 MaxLength="800"
                                 metro:TextBoxHelper.Watermark="Напишите комментарий..."/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="10,0,0,0">
                            <Button x:Name="BtnDeleteComment" Content="Удалить" Width="80" Height="34" Margin="0,0,8,0"
                                    Background="#444444" Foreground="White" BorderThickness="0" FontWeight="SemiBold" Cursor="Hand" Click="BtnDeleteComment_Click" Visibility="Collapsed">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <Button x:Name="BtnSubmitComment" Content="Отправить" Width="100" Height="34"
                                    Background="#E50914" Foreground="White" BorderThickness="0" FontWeight="SemiBold" Cursor="Hand" Click="BtnAddComment_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </Grid>
                    <!-- Предупреждение если нет оценки -->
                    <TextBlock x:Name="TxtCommentWarning" Text="Вы не можете оставить комментарий, пока не оцените этот фильм." Foreground="#E50914" FontSize="12" Margin="0,6,0,0" Visibility="Collapsed" HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>

            <!-- ══ Нижняя панель: кнопки управления ════════════════════════════ -->
            <Border Grid.Row="3" Padding="24,16" Margin="0,12,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">

                    <!-- Кнопка «Поделиться» -->
                    <Button Width="160" 
                            Style="{StaticResource BottomButtonStyle}"
                            Background="#0078D7"
                            Click="BtnShare_Click"
                            Margin="0,0,12,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <iconPacks:PackIconMaterial Kind="ShareVariant" Width="16" Height="16" Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Поделиться" Foreground="White" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Кнопка «Закрыть» -->
                    <Button Content="Закрыть"
                            Width="120"
                            Style="{StaticResource BottomButtonStyle}"
                            Background="#E50914"
                            Click="BtnClose_Click"/>

                </StackPanel>
            </Border>

        </Grid>
    </Border>
</Window>

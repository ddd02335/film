<Window x:Class="MovieApp.MovieDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        Width="740"
        SizeToContent="Height"
        ResizeMode="NoResize">

    <Window.Resources>
        <!-- Кнопка закрытия окна: круглая, серая, красная при наведении -->
        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="Width"           Value="32"/>
            <Setter Property="Height"          Value="32"/>
            <Setter Property="Background"      Value="#2A2A2A"/>
            <Setter Property="Foreground"      Value="#B3B3B3"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="16"
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E50914"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#C0000D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!--
        Внешний Border — даёт тень и скруглённые углы для безрамочного окна.
        MouseDown="OnDragWindow" позволяет перетаскивать окно за любую область.
    -->
    <Border Background="#1A1A1A"
            CornerRadius="14"
            MouseDown="OnDragWindow"
            Margin="12">
        <Border.Effect>
            <DropShadowEffect Color="#000000"
                              BlurRadius="30"
                              Opacity="0.8"
                              ShadowDepth="0"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <!-- строка с постером + деталями -->
                <RowDefinition Height="Auto"/>
                <!-- строка с описанием -->
                <RowDefinition Height="Auto"/>
                <!-- строка с кнопками -->
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ══ Блок: постер + детали ══════════════════════════════════════ -->
            <Grid Grid.Row="0" Margin="24,24,24,0">
                <Grid.ColumnDefinitions>
                    <!-- постер -->
                    <ColumnDefinition Width="220"/>
                    <!-- детали -->
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- постер фильма -->
                <Border Grid.Column="0"
                        CornerRadius="10"
                        ClipToBounds="True"
                        Width="220" Height="310"
                        VerticalAlignment="Top">
                    <!-- заглушка если постера нет -->
                    <Grid>
                        <Border Background="#252525">
                            <TextBlock Text="🎬" FontSize="56"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <!-- постер поверх заглушки -->
                        <Image x:Name="PosterImage"
                               Stretch="UniformToFill"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Grid>
                </Border>

                <!-- детали фильма -->
                <StackPanel Grid.Column="1"
                            Margin="24,0,0,0"
                            VerticalAlignment="Top">

                    <!-- название фильма -->
                    <TextBlock x:Name="TxtTitle"
                               Text="Название фильма"
                               FontFamily="Segoe UI"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="#FFFFFF"
                               TextWrapping="Wrap"
                               LineHeight="28"/>

                    <!-- год выпуска -->
                    <TextBlock x:Name="TxtYear"
                               Text="—"
                               FontFamily="Segoe UI"
                               FontSize="14"
                               Foreground="#6B6B6B"
                               Margin="0,8,0,0"/>

                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <!-- жанры -->
                        <Border Background="#252525"
                                CornerRadius="4"
                                Padding="8,4">
                            <TextBlock x:Name="TxtGenres"
                                       Text="Жанры не указаны"
                                       FontFamily="Segoe UI"
                                       FontSize="12"
                                       Foreground="#B3B3B3"/>
                        </Border>

                        <!-- возрастной рейтинг -->
                        <Border Background="#1A1A1A"
                                BorderBrush="#333333"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="8,4"
                                Margin="10,0,0,0">
                            <TextBlock x:Name="TxtAgeRating"
                                       Text="12+"
                                       FontFamily="Segoe UI"
                                       FontSize="12"
                                       FontWeight="Bold"
                                       Foreground="#FFFFFF"/>
                        </Border>
                    </StackPanel>

                    <!-- разделитель -->
                    <Rectangle Height="1"
                               Fill="#2A2A2A"
                               Margin="0,16,0,16"/>

                    <!-- краткая метаинформация -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="Рейтинг Кинопоиска:"
                                   FontFamily="Segoe UI"
                                   FontSize="13"
                                   Foreground="#6B6B6B"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtKpRating"
                                   Text="—"
                                   FontFamily="Segoe UI"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="#E50914"
                                   Margin="8,0,0,0"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- кнопка закрытия — в правом верхнем углу блока деталей -->
                    <Button Style="{StaticResource CloseButtonStyle}"
                            Content="✕"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="0,0,0,8"
                            Click="BtnClose_Click">
                        <Button.RenderTransform>
                            <TranslateTransform Y="-60"/>
                        </Button.RenderTransform>
                    </Button>

                </StackPanel>
            </Grid>

            <!-- ══ Блок: описание ══════════════════════════════════════════════ -->
            <Border Grid.Row="1"
                    Background="#141414"
                    CornerRadius="8"
                    Margin="24,20,24,0"
                    Padding="16,14">
                <StackPanel>
                    <TextBlock Text="Описание"
                               FontFamily="Segoe UI"
                               FontSize="12"
                               Foreground="#6B6B6B"
                               Margin="0,0,0,8"/>
                    <TextBlock x:Name="TxtDescription"
                               Text="Описание отсутствует."
                               FontFamily="Segoe UI"
                               FontSize="14"
                               Foreground="#D0D0D0"
                               TextWrapping="Wrap"
                               LineHeight="22"/>
                </StackPanel>
            </Border>

            <!-- ══ Нижняя панель: кнопки управления ════════════════════════════ -->
            <Border Grid.Row="2" Padding="24,16" Margin="0,12,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Закрыть"
                            Width="120" Height="38"
                            FontFamily="Segoe UI"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="#FFFFFF"
                            Background="#E50914"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="BtnClose_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd"
                                        Background="{TemplateBinding Background}"
                                        CornerRadius="8"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#FF1E27"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#C0000D"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Border>

        </Grid>
    </Border>
</Window>
